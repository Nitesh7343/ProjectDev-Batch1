{
  "name": "park-and-ride",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
